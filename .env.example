# ═══════════════════════════════════════════════════════════════
#  KhabarPati — Environment Variables
#  Copy this to .env.local and fill in your values.
#  NEVER commit .env.local to git.
# ═══════════════════════════════════════════════════════════════

# ─── Supabase ──────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-side only, NEVER expose to client
# Used by the crawler and admin APIs
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Site ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://khabarpati.com

# ─── Crawler (Python) ─────────────────────────────────────────
# These are used by crawler/crawler.py only
CRAWLER_SUPABASE_URL=https://your-project-id.supabase.co
CRAWLER_SUPABASE_KEY=your-service-role-key-here

# ─── Optional: Twilio (for SMS OTP fallback) ──────────────────
# Supabase Auth handles OTP natively via Twilio — configure in
# Supabase dashboard: Authentication → Providers → Phone
# No env vars needed here unless you use a custom SMS provider.
