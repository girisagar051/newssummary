# ═══════════════════════════════════════════════════════════════
#  KhabarPati — .gitignore
# ═══════════════════════════════════════════════════════════════

# ─── Dependencies ─────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js ──────────────────────────────────────────────────
.next/
out/
build/
.swc/

# ─── Environment variables — NEVER commit these ───────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# .env.example is intentionally NOT ignored (safe template)

# ─── Supabase local dev ───────────────────────────────────────
supabase/.temp/
supabase/config.toml
# Keep migrations/ and seed.sql in git

# ─── Crawler ──────────────────────────────────────────────────
crawler/__pycache__/
crawler/*.pyc
crawler/.venv/
crawler/venv/
crawler/env/
crawler/crawler.log
crawler/*.log

# ─── Vercel ───────────────────────────────────────────────────
.vercel/

# ─── MCP config (contains project refs / credentials) ─────────
.mcp.json

# ─── TypeScript ───────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Testing / coverage ───────────────────────────────────────
coverage/
.nyc_output/
playwright-report/
test-results/

# ─── OS files ─────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Desktop.ini

# ─── Editor / IDE ─────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# ─── Logs ─────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Misc ─────────────────────────────────────────────────────
*.pem
.cache/
dist/
